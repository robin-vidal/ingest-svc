{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Watcher": {
    "Path": "/path/to/watch",
    "StandId": "stand-id-here",
    "ProcessedPath": "/path/to/processed",
    "FailedPath": "/path/to/failed"
  },
  "Resize": {

    "MaxHeight": 800
  },
  "Storage": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSSL": false,
    "Bucket": "photos",
    "FullPrefix": "full",
    "LowPrefix": "low"
  }
}
